# Dependencies
node_modules/

# Build output
out/
dist/
release/
*.tsbuildinfo

# Electron-builder
*.blockmap
*.snap
*.deb
*.rpm
*.AppImage
*.dmg
*.exe
!assets/icon.ico

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Environment
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# User config (generated at runtime with local paths)
freela-radar.config.json

# Banco de dados local (gerado em runtime a partir de schema/migrate/seed).
# NUNCA versionar: a tabela settings pode conter chaves de API e dados pessoais.
# O banco "base" dos alunos é recriado automaticamente no primeiro `npm run dev`.
*.db
*.db-shm
*.db-wal
!examples/*.example.db

# Workspace de exemplo é versionado (pasta workspace/) para servir de referência.
# Os dados reais de uso ficam no caminho configurado em Settings → workspace.
# Exceção à regra *.log acima: mantém os logs de execução de exemplo.
!workspace/**/*.log

# Playwright browsers (downloaded at runtime)
playwright-browsers/

# Drizzle generated migrations (regenerated via npm run db:generate)
drizzle/meta/

# Coverage & tests
coverage/
.nyc_output/

# Misc
*.tgz
.cache/
.temp/
.tmp/
